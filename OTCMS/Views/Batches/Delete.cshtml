@model OTCMS.Components.Batch

@{
    ViewData["Title"] = "Delete Batch";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="text-danger mb-4">Delete Batch</h1>

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4 class="mb-0">Are you sure you want to delete this batch?</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.BatchName)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.BatchName)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.StartDate)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.StartDate)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.EndDate)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.EndDate)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.HandledBy)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.HandledBy)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.Status)</dt>
            <dd class="col-sm-9">@(Model.Status ? "Active" : "Inactive")</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.Timings)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Timings)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.Duration)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Duration)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.Fee)</dt>
            <dd class="col-sm-9">@String.Format("{0:C}", Model.Fee)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.Description)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Description)</dd>

            <dt class="col-sm-3 fw-bold">Course</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Course.NameOfTheCourse)</dd>
        </dl>

        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="BatchId" />
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash"></i> Confirm Delete
            </button>
            <a asp-action="Index" class="btn btn-secondary ms-2">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </form>
    </div>
</div>
<style>
    body {
        /* background-image: url('@Url.Content("~/images/new_background.jpg")'); */
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
    }
</style>

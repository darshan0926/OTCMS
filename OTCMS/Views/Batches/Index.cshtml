@using OTCMS.Utility
@model PaginatedList<Batch>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1>Batch Management</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Create New Batch</a>

    <form asp-action="Index" method="get" style="display:inline-block; margin-left:15px;">
        <div class="form-actions no-color my-3">
            <div class="card shadow-sm border-0 p-3">
                <div class="d-flex flex-column flex-md-row align-items-center gap-3">

                    <!-- Label + Dropdown side by side -->
                    <div class="d-flex align-items-center gap-2">
                        <label class="fw-semibold mb-0">Filter by Course Name</label>
                        <select name="courseId"
                                asp-items="@(ViewData["CourseId"] as SelectList)"
                                class="form-select"
                                style="min-width: 240px;"
                                onchange="this.form.submit()">
                            <option value="">-- Select Course --</option>
                        </select>
                    </div>

                    <!-- Reset Button -->
                    <a asp-action="Index">Reset</a>

                </div>
            </div>
        </div>
    </form>
</p>

<table class="table table-striped table-bordered">
    <thead class="thead-dark">
        <tr>
            <th>
                <!-- ✅ Keep filters while sorting -->
                <a asp-action="Index"
                   asp-route-sortOrder="@ViewData["NameSort"]"
                   asp-route-currentFilter="@ViewData["CurrentFilter"]"
                   asp-route-currentCourseId="@ViewData["CurrentCourseId"]">
                    BatchName
                </a>
            </th>
            <th>StartDate</th>
            <th>EndDate</th>
            <th>HandledBy</th>
            <th>Status</th>
            <th>Timings</th>
            <th>Duration</th>
            <th>Fee</th>
            <th>Description</th>
            <th>Course</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.BatchName)</td>
                <td>@Html.DisplayFor(modelItem => item.StartDate)</td>
                <td>@Html.DisplayFor(modelItem => item.EndDate)</td>
                <td>@Html.DisplayFor(modelItem => item.HandledBy)</td>
                <td>@(item.Status ? "Active" : "Inactive")</td>
                <td>@Html.DisplayFor(modelItem => item.Timings)</td>
                <td>@Html.DisplayFor(modelItem => item.Duration)</td>
                <td>@String.Format("{0:C}", item.Fee)</td>
                <td>@Html.DisplayFor(modelItem => item.Description)</td>
                <td>@Html.DisplayFor(modelItem => item.Course.NameOfTheCourse)</td>
                <td>
                    <a asp-action="Edit"
                       asp-route-id="@item.BatchId"
                       asp-route-sortOrder="@ViewData["CurrentSort"]"
                       asp-route-pageNumber="@Model.PageIndex"
                       asp-route-currentFilter="@ViewData["CurrentFilter"]"
                       asp-route-currentCourseId="@ViewData["CurrentCourseId"]"
                       class="btn btn-primary btn-sm">
                        Edit
                    </a>                    <a asp-action="Details" asp-route-id="@item.BatchId" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.BatchId" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@{
    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
}

<!-- ✅ Pagination should keep Search + Dropdown selection + Sorting -->
<a asp-action="Index"
   asp-route-sortOrder="@ViewData["CurrentSort"]"
   asp-route-pageNumber="@(Model.PageIndex - 1)"
   asp-route-currentFilter="@ViewData["CurrentFilter"]"
   asp-route-currentCourseId="@ViewData["CurrentCourseId"]"
   class="btn btn-default @prevDisabled">
    Previous
</a>

<span> @Model.PageIndex / @Model.TotalPages </span>

<a asp-action="Index"
   asp-route-sortOrder="@ViewData["CurrentSort"]"
   asp-route-pageNumber="@(Model.PageIndex + 1)"
   asp-route-currentFilter="@ViewData["CurrentFilter"]"
   asp-route-currentCourseId="@ViewData["CurrentCourseId"]"
   class="btn btn-default @nextDisabled">
    Next
</a>

<style>
    body {
        /* background-image: url('@Url.Content("~/images/new_background.jpg")'); */
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
    }
    
    }
</style>

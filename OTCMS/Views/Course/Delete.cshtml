@model OTCMS.Components.Course

@{
    ViewData["Title"] = "Delete Course";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="text-danger mb-4">Delete Course</h1>

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4 class="mb-0">Are you sure you want to delete this course?</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.NameOfTheCourse)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.NameOfTheCourse)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.CourseDescription)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.CourseDescription)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.Status)</dt>
            <dd class="col-sm-9">
                @(Model.Status ? "Active" : "Inactive")
            </dd>

            <dt class="col-sm-3 fw-bold">Course Logo</dt>
            <dd class="col-sm-9">
                <img src="@Model.CourseLogoImagePath" alt="@Model.NameOfTheCourse" class="img-thumbnail" width="200" height="200" />
            </dd>

            <!-- ✅ New Section for PDF -->
            <dt class="col-sm-3 fw-bold">Course Content (PDF)</dt>
            <dd class="col-sm-9">
                @if (!string.IsNullOrEmpty(Model.CourseContentFilePath))
                {
                    <a href="@Model.CourseContentFilePath" target="_blank" class="btn btn-outline-info btn-sm">
                        View PDF
                    </a>
                }
                else
                {
                    <span class="text-muted">No PDF uploaded</span>
                }
            </dd>
        </dl>

        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="CourseId" />
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash"></i> Confirm Delete
            </button>
            <a asp-action="Index" class="btn btn-secondary ms-2">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </form>
    </div>
</div>

<style>
    body {
        /* background-image: url('@Url.Content("~/images/new_background.jpg")'); */
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
    }
</style>

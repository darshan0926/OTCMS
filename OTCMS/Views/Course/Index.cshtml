@using OTCMS.Utility
@model PaginatedList<OTCMS.Components.Course>

@{
    ViewData["Title"] = "Course List";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1>Course Management</h1>

@if (TempData["msg"] != null)
{
    <div class="alert alert-warning mt-3">
        @TempData["msg"]
    </div>
}

<p class="mt-3">
    <a asp-action="Create" class="btn btn-success">Create New Course</a>

    <form asp-action="Index" method="get" class="mt-3">
        <div class="form-actions no-color">
            <div class="card shadow-sm border-0 p-3">
                <div class="d-flex flex-column flex-md-row align-items-center gap-2">
                    <div class="input-group">
                        <input type="text"
                               name="searchString"
                               class="form-control"
                               placeholder="Search by Course Name..."
                               value="@ViewData["CurrentFilter"]" />
                    </div>

                    <input type="submit" value="Search" class="btn btn-primary px-4" />

                    <a asp-action="Index" class="btn btn-link">Reset</a>
                </div>
            </div>
        </div>
    </form>
</p>

<table class="table table-striped table-bordered mt-3">
    <thead class="thead-dark">
        <tr>
            <th>
                <a asp-action="Index"
                   asp-route-sortOrder="@ViewData["NameSort"]"
                   asp-route-currentFilter="@ViewData["CurrentFilter"]">
                    Name
                </a>
            </th>

            <th style="width:450px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                Course Description
            </th>

            <th>Status</th>

            <th>Course Logo</th>

            <th>Course Content</th>

            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.NameOfTheCourse</td>

                    <td>@item.CourseDescription</td>

                    <td>@(item.Status ? "Active" : "Inactive")</td>

                    <td style="text-align:center; vertical-align:middle;">
                        <img src="@item.CourseLogoImagePath"
                             width="120"
                             height="120"
                             alt="@item.NameOfTheCourse" />
                    </td>

                    <td>
                        @if (!string.IsNullOrEmpty(item.CourseContentFilePath))
                        {
                            <a href="@item.CourseContentFilePath"
                               target="_blank"
                               class="btn btn-outline-info btn-sm">
                                View PDF
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">No PDF Uploaded</span>
                        }
                    </td>

                    <td>
                        <a asp-action="Edit" asp-route-id="@item.CourseId" class="btn btn-primary btn-sm">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.CourseId" class="btn btn-info btn-sm">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.CourseId" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center text-muted">No courses to show.</td>
            </tr>
        }
    </tbody>
</table>

@{
    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
}

<div class="d-flex align-items-center gap-2 mt-3">
    <a asp-action="Index"
       asp-route-sortOrder="@ViewData["CurrentSort"]"
       asp-route-pageNumber="@(Model.PageIndex - 1)"
       asp-route-currentFilter="@ViewData["CurrentFilter"]"
       class="btn btn-outline-secondary @prevDisabled">
        Previous
    </a>

    <span class="fw-semibold"> @Model.PageIndex / @Model.TotalPages </span>

    <a asp-action="Index"
       asp-route-sortOrder="@ViewData["CurrentSort"]"
       asp-route-pageNumber="@(Model.PageIndex + 1)"
       asp-route-currentFilter="@ViewData["CurrentFilter"]"
       class="btn btn-outline-secondary @nextDisabled">
        Next
    </a>
</div>

<style>
    body {
        /* background-image: url('@Url.Content("~/images/new_background.jpg") '); */ background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
    }
</style>
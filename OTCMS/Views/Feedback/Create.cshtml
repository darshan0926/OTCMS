@model OTCMS.Components.Feedback

@{

    ViewData["Title"] = "Create";

    Layout = "~/Views/Shared/_StudentLayout.cshtml";

}

<style>

    /* ====== Blue Theme Feedback Form Styles (Inline) ====== */

    /* Whole page background */

    /* Whole page background */
    .fb-page {
        min-height: 100vh;
        padding: 40px 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #ffffff; /* ✅ plain white background */
    }


    /* Card container */

    .fb-card {
        width: 100%;
        max-width: 560px;
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 18px 40px rgba(13, 71, 161, 0.18);
        overflow: hidden;
        border: 1px solid rgba(30, 136, 229, 0.15);
        position: relative;
    }

        /* Card top accent */

        .fb-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            height: 6px;
            width: 100%;
            background: linear-gradient(90deg, #1e88e5, #0d47a1);
        }

    /* Header area */

    .fb-header {
        padding: 26px 26px 10px 26px;
        text-align: center;
    }

    .fb-title {
        margin: 0;
        color: #0d47a1;
        font-weight: 700;
        letter-spacing: 0.2px;
        font-size: 36px;
    }

    .fb-subtitle {
        margin: 8px 0 0 0;
        color: #607d8b;
        font-size: 16px;
    }

    /* Body area */

    .fb-body {
        padding: 20px 26px 26px 26px;
    }

    /* Small divider */

    .fb-divider {
        border: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(30,136,229,0.35), transparent);
        margin: 14px 0 18px;
    }

    /* Labels */

    .fb-body label,
    .fb-body .control-label {
        color: #0d47a1;
        font-weight: 600;
        margin-bottom: 6px;
        display: inline-block;
    }

    /* Inputs */

    .fb-input {
        border-radius: 10px;
        border: 1px solid rgba(144, 202, 249, 0.9);
        padding: 11px 12px;
        transition: all 0.25s ease;
        background: #fbfdff;
    }

        .fb-input:focus {
            border-color: #1e88e5;
            box-shadow: 0 0 0 4px rgba(30, 136, 229, 0.18);
            outline: none;
            background: #ffffff;
        }

    /* Form group spacing */

    .fb-body .form-group {
        margin-bottom: 16px;
    }

    /* Validation summary - make it cleaner */

    .fb-body .text-danger {
        font-size: 13px;
    }

    /* Button */

    .fb-btn {
        width: 100%;
        border: none;
        color: #fff !important;
        font-weight: 600;
        padding: 12px 18px;
        border-radius: 30px;
        background: linear-gradient(135deg, #1e88e5, #0d47a1);
        box-shadow: 0 10px 20px rgba(13, 71, 161, 0.22);
        transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    }

        .fb-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 14px 26px rgba(13, 71, 161, 0.28);
            filter: brightness(1.03);
        }

        .fb-btn:active {
            transform: translateY(0px);
            box-shadow: 0 8px 16px rgba(13, 71, 161, 0.22);
        }

    /* Footer link area */

    .fb-footer {
        padding: 0 26px 22px 26px;
        text-align: center;
    }

    .fb-link {
        color: #1565c0;
        font-weight: 600;
        text-decoration: none;
        transition: color 0.2s ease, text-decoration-color 0.2s ease;
    }

        .fb-link:hover {
            color: #0d47a1;
            text-decoration: underline;
            text-decoration-thickness: 2px;
        }

    /* Responsive */

    @@media (max-width: 480px) {

        .fb-header, .fb-body, .fb-footer {
            padding-left: 18px;
            padding-right: 18px;
        }

        .fb-title {
            font-size: 22px;
        }
    }
</style>

<div class="fb-page">
    <div class="fb-card">

        <div class="fb-header">
            <h2 class="fb-title">Feedback</h2>
            <p class="fb-subtitle">We value your thoughts 💙 Please share your feedback below.</p>
            <hr class="fb-divider" />
        </div>

        <div class="fb-body">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group">
                    <label asp-for="Name" class="control-label"></label>
                    <input asp-for="Name" class="form-control fb-input" placeholder="Enter your name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Subject" class="control-label"></label>
                    <input asp-for="Subject" class="form-control fb-input" placeholder="Enter subject" />
                    <span asp-validation-for="Subject" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description" class="control-label"></label>
<textarea asp-for="Description" class="form-control fb-input" cols="30" rows="5"
          placeholder="Write your feedback here..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email" class="control-label"></label>
                    <input asp-for="Email" class="form-control fb-input" placeholder="example@mail.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Phone" class="control-label"></label>
                    <input asp-for="Phone" class="form-control fb-input" placeholder="Enter phone number" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="form-group" style="margin-top: 18px;">
                    <input type="submit" value="Create" class="btn fb-btn" />
                </div>
            </form>
        </div>

        <div class="fb-footer">
            <a asp-action="Index" class="fb-link">← Back to List</a>
        </div>

    </div>
</div>

@section Scripts {

    @{

        await Html.RenderPartialAsync("_ValidationScriptsPartial");

    }

}


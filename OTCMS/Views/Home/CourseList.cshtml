@model OTCMS.Components.Course
@{
    ViewData["Title"] = "Course Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">

    <!-- ✅ Course Header -->
    <div class="row align-items-center mb-4">
        <div class="col-md-8">
            <h2 class="fw-bold text-primary">@Model.NameOfTheCourse</h2>
            <p class="text-muted">@Model.CourseDescription</p>
        </div>

        <div class="col-md-4 text-md-end">
            <img src="@Url.Content(Model.CourseLogoImagePath)"
                 alt="@Model.NameOfTheCourse Logo"
                 class="img-fluid rounded shadow-sm"
                 style="max-height:130px;" />
        </div>
    </div>

    <hr />

    <!-- ✅ Batch Section -->
    <h4 class="fw-semibold mb-3">Available Batches</h4>

    @if (Model.Batches != null && Model.Batches.Any())
    {
        <div class="row g-4">
            @foreach (var batch in Model.Batches)
            {
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="card h-100 shadow-sm border-0 batch-card">
                        <div class="card-body d-flex flex-column">

                            <h5 class="fw-bold mb-2">@batch.BatchName</h5>

                            <ul class="list-unstyled small text-muted mb-3">
                                <li><strong>Start:</strong> @batch.StartDate.ToString("dd MMM yyyy")</li>
                                <li><strong>End:</strong> @batch.EndDate.ToString("dd MMM yyyy")</li>
                                <li><strong>Trainer:</strong> @batch.HandledBy</li>
                                <li><strong>Timings:</strong> @batch.Timings</li>
                                <li><strong>Duration:</strong> @batch.Duration</li>
                                <li class="fw-semibold text-dark mt-2">
                                    Fee: ₹@batch.Fee
                                </li>
                            </ul>

                            <!-- ✅ CTA -->
                            <div class="mt-auto">
                                <a asp-controller="User"
                                   asp-action="Register"
                                   class="btn btn-primary w-100">
                                    View Details
                                </a>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No batches available for this course currently.
        </div>
    }
</div>

<!-- ✅ UI Enhancements -->
<style>
    .batch-card {
        transition: all 0.2s ease-in-out;
        border-radius: 14px;
    }

        .batch-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 10px 28px rgba(0,0,0,0.12);
        }
</style>
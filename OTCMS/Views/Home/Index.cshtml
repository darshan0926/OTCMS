@model IEnumerable<OTCMS.Components.Course>

@{
    ViewData["Title"] = "Home Page";
}

<partial name="DisplaySlider" />

<div class="container-fluid mt-4 text-center text-dark">

    <!-- Hero Section -->
    <section class="hero text-black py-5" style="background-color:cornsilk;">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-9 text-start">
                    <h1 class="display-4 fw-bold">Empowering Your Tech Career</h1>
                    <p class="lead">
                        Learn coding, development, and placement skills with structured courses and real-world projects.
                    </p>

                    <div class="row mt-4">
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li class="mb-2">✅ <strong>Industry-Led Curriculum:</strong> Master the latest tech stacks.</li>
                                <li class="mb-2">✅ <strong>Hands-on Projects:</strong> Build real-world applications.</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li class="mb-2">✅ <strong>Placement Support:</strong> Dedicated career guidance.</li>
                                <li class="mb-2">✅ <strong>Flexible Learning:</strong> Learn at your own pace.</li>
                            </ul>
                        </div>
                    </div>
                    <a href="#coursedetails" class="btn btn-primary btn-lg mt-3">
                        Explore Courses
                    </a>
                </div>

                <!-- Right Side: Trainer Photo -->
                <div class="col-md-3 text-center">
                    <img src="@Url.Content("~/images/karyanova logo.png")"
                         alt="KaryaNova Logo"
                         class="img-fluid" />
                </div>
            </div>
        </div>
    </section>

    <!-- Courses Section -->
    <section id="coursedetails" class="courses-section py-5">
        <div class="container">
            <h2 class="fw-bold mb-4 text-center">Our Latest .Net Ecosystem Courses</h2>
            <div class="courses-grid">
                @foreach (var course in Model)
                {
                    <div class="course-box">
                        <div class="course-icon">
                            <img src="@Url.Content(course.CourseLogoImagePath)"
                                 alt="@course.NameOfTheCourse Logo"
                                 class="img-fluid" />
                        </div>
                        <h3>@course.NameOfTheCourse</h3>
                        <a asp-controller="Home" asp-action="CourseList" asp-route-id="@course.CourseId"
                           class="btn btn-course">
                            Learn More
                        </a>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- Metrics Section -->
    <section class="impact-metrics">
        <div class="metrics-header">
            <h2>Numbers That Inspire</h2>
            <p>Explore our thriving learning ecosystem with proven results.</p>
        </div>
        <div class="metrics-grid">
            <div class="metric-box">
                <div class="metric-icon">🎓</div>
                <h3>50K+ Happy Students</h3>
                <p>Success stories from every corner of India.</p>
            </div>
            <div class="metric-box">
                <div class="metric-icon">📚</div>
                <h3>120+ Courses Offered</h3>
                <p>Covering tech, business, design, and more.</p>
            </div>
            <div class="metric-box">
                <div class="metric-icon">✅</div>
                <h3>96% Success Rate</h3>
                <p>Consistent placement and career growth.</p>
            </div>
            <div class="metric-box">
                <div class="metric-icon">👨‍🏫</div>
                <h3>60+ Expert Mentors</h3>
                <p>Guidance from industry veterans and educators.</p>
            </div>
        </div>
    </section>
</div>
<!-- Footer Section -->
<footer class="footer-custom bg-dark text-light border-top mt-5">
    <div class="container-fluid py-3">
        <div class="row justify-content-center align-items-start">

            <!-- Logo + Taglines -->
            <div class="col-md-3 text-center mb-2">
                <img src="~/images/karyanova_logo6.png" alt="KaryaNova Logo" class="img-fluid" style="max-height:80px;" />
                <p class="mt-1 small text-accent">Where Ambition Meets Opportunity</p>
                <p class="small">Learn. Build. Grow.</p>
            </div>

            <!-- Quick Links -->
            <div class="col-md-3 mb-2">
                <h6 class="fw-semibold mb-2">Quick Links</h6>
                <ul class="list-unstyled small mb-0">
                    <li><a asp-controller="Home" asp-action="Index" class="footer-link">Home</a></li>
                    <li><a href="#coursedetails" class="footer-link">Courses</a></li>
                    @* <li><a href="#hero" class="footer-link">About</a></li> *@
                </ul>
            </div>

            <!-- Contact Info -->
            <div class="col-md-3 mb-2">
                <h6 class="fw-semibold mb-2">Reach Us</h6>
                <p class="mb-1 small">
                    📞 <a href="tel:+919876543210" class="text-accent">98765 43210</a>
                </p>

                <p class="mb-0 small">
                    📧 <a href="mailto:info@karyanova.com" class="text-accent">info@karyanova.com</a>
                </p>

            </div>

            <!-- Social Media -->
            <div class="col-md-3 mb-2">
                <h6 class="fw-semibold mb-2">Follow Us</h6>
                <a href="https://www.instagram.com" target="_blank" class="footer-icon"><i class="bi bi-instagram"></i></a>
                <a href="https://www.facebook.com" target="_blank" class="footer-icon"><i class="bi bi-facebook"></i></a>
                <a href="https://www.linkedin.com" target="_blank" class="footer-icon"><i class="bi bi-linkedin"></i></a>
            </div>

        </div>

        @* <div class="text-center small">
&copy; 2026 <span class="text-accent">KaryaNova</span>. All rights reserved.
</div> *@
    </div>
</footer>

<style>
    body {
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
    }

    /* Metrics Styling */
    .impact-metrics {
        background: #ffffff;
        color: #000;
        padding: 60px 20px;
        text-align: center;
        font-family: 'Segoe UI', sans-serif;
    }

    .metrics-header h2 {
        font-size: 2.5rem;
        margin-bottom: 10px;
        color: #007bff;
        padding: 10px 0;
    }

    .metrics-header p {
        font-size: 1.2rem;
        margin-bottom: 40px;
        color: #333;
    }

    .metrics-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 30px;
        max-width: 1000px;
        margin: 0 auto;
    }

    .metric-box {
        background: #f9f9f9;
        border: 1px solid #ddd;
        border-radius: 12px;
        padding: 30px 20px;
        transition: transform 0.3s ease;
    }

        .metric-box:hover {
            transform: translateY(-5px);
        }

    .metric-icon {
        font-size: 2.5rem;
        margin-bottom: 15px;
    }

    .metric-box h3 {
        font-size: 1.4rem;
        margin-bottom: 10px;
        color: #007bff;
        font-weight: bold;
    }

    .metric-box p {
        font-size: 1rem;
        color: #333;
    }

    /* Courses Section Styling */
    .courses-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 30px;
        max-width: 1000px;
        margin: 0 auto;
    }

    .course-box {
        background: #ffffff;
        border: 2px solid #007bff;
        border-radius: 12px;
        padding: 30px 20px;
        text-align: center;
        transition: transform 0.4s ease, box-shadow 0.4s ease;
        /* NEW: equal height and button alignment */
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

        .course-box:hover {
            transform: translateY(-8px) scale(1.03);
            box-shadow: 0 10px 25px rgba(0, 123, 255, 0.3);
        }

    .course-icon img {
        max-height: 120px;
        margin-bottom: 15px;
        transition: transform 0.4s ease;
    }

    .course-box:hover .course-icon img {
        transform: scale(1.1);
    }

    .course-box h3 {
        font-size: 1.4rem;
        margin-bottom: 10px;
        color: #007bff;
        font-weight: bold;
    }

    .btn-course {
        background: #007bff;
        color: #fff;
        font-weight: bold;
        border-radius: 8px;
        padding: 10px 20px;
        transition: background 0.3s ease, transform 0.3s ease;
        text-decoration: none;
        /* ensures button stays at bottom */
        margin-top: auto;
    }

        .btn-course:hover {
            background: #0056b3;
            transform: scale(1.05);
        }
</style>

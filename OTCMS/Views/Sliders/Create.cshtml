@model OTCMS.Components.Slider

@{
    ViewData["Title"] = "Create Slider";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mb-4 text-primary">Create Slider</h1>

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">Slider Information</h4>
    </div>
    <div class="card-body">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="SliderName" class="form-label">Slider Name</label>
                <input asp-for="SliderName" class="form-control" placeholder="Enter Slider Name" />
                <span asp-validation-for="SliderName" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="SliderStatus" />
                <label class="form-check-label" asp-for="SliderStatus">Active Status</label>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SliderText" class="form-label">Slider Text</label>
                <input asp-for="SliderText" class="form-control" placeholder="Enter Slider Text" />
                <span asp-validation-for="SliderText" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SliderDescriptionText" class="form-label">Slider Description</label>
                <textarea asp-for="SliderDescriptionText" class="form-control" rows="3" placeholder="Enter Description"></textarea>
                <span asp-validation-for="SliderDescriptionText" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SliderOrderNo" class="form-label">Order No</label>
                <input asp-for="SliderOrderNo" class="form-control" placeholder="Enter Order Number" />
                <span asp-validation-for="SliderOrderNo" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CreatedOn" class="form-label">Created On</label>
                <input asp-for="CreatedOn" class="form-control" type="date" />
                <span asp-validation-for="CreatedOn" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SliderUrl" class="form-label">Slider URL</label>
                <input asp-for="SliderUrl" class="form-control" placeholder="Enter URL" />
                <span asp-validation-for="SliderUrl" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="form-label">Selected Slider Image</label>
                <div class="border p-2 text-center">
                    @if (!string.IsNullOrEmpty(Model?.SliderImagePath))
                    {
                        <img src="@Model.SliderImagePath" alt="@Model.SliderName"
                             class="slider-img img-thumbnail" width="300" height="150" id="prevSliderImage" />
                    }
                    else
                    {
                        <img src="~/images/placeholder.png" alt="No image selected"
                             class="slider-img img-thumbnail" width="300" height="150" id="prevSliderImage" />
                    }
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SliderImage" class="form-label">Upload Slider Image</label>
                <input type="file" asp-for="SliderImage" class="form-control" onchange="preview(event)" />
                <span asp-validation-for="SliderImage" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="Create" class="btn btn-success" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
            </div>
        </form>
    </div>
</div>

<style>
    body {
        /* background-image: url('@Url.Content("~/images/new_background.jpg")'); */
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
    }
</style>

<script type="text/javascript">
    function preview(event) {
        var refImg = document.getElementById('prevSliderImage');
        refImg.src = URL.createObjectURL(event.target.files[0]);
    }
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

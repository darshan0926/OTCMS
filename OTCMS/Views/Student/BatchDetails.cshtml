@using OTCMS.Components.ViewModels
@model BatchDetailsViewModel

@{
    ViewData["Title"] = "Batch Details";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
}

<div class="container py-4">

    <!-- ✅ Header / Breadcrumb -->
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-4">
        <div>
           
            <h2 class="fw-bold mb-0">
                <span class="text-primary">Batch:</span> @Model.Batch.BatchName
            </h2>
            <p class="text-muted mb-0">Access notes and videos shared for each session.</p>
        </div>

        <div class="mt-3 mt-md-0">
            <span class="badge rounded-pill @(Model.Batch.Status ? "bg-success" : "bg-secondary") px-3 py-2">
                @(Model.Batch.Status ? "Active" : "Inactive")
            </span>
        </div>
    </div>

    <!-- ✅ Top Summary Cards -->
    <div class="row g-4 mb-4">
        <!-- Course Card -->
        <div class="col-lg-5">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center gap-3">
                        <img src="@Url.Content(Model.Course.CourseLogoImagePath)"
                             alt="@Model.Course.NameOfTheCourse Logo"
                             class="rounded-3 border"
                             style="width:72px;height:72px;object-fit:contain;background:#fff;" />

                        <div>
                            <h5 class="fw-bold mb-1 justify-content-between" style="font-size:x-large">@Model.Course.NameOfTheCourse</h5>
                            <p class="text-muted mb-0 fw-medium justify-content-between">
                                @Model.Course.CourseDescription
                            </p>
                        </div>
                    </div>

                    <hr class="my-3" />

                    <div class="small text-muted">
                        <div class="d-flex justify-content-between" style="font-size:medium">
                            <span><i class="bi bi-journal-text me-1"></i> Total Sessions</span>
                            <span class="fw-semibold text-dark">@Model.Contents.Count</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Batch Card -->
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Batch Overview</h5>

                    <div class="row g-3 small">
                        <div class="col-md-6">
                            <div class="info-tile" style="font-size:medium">
                                <div class="text fw-bold">Start Date</div>
                                <div class="text-muted">@Model.Batch.StartDate.ToString("dd MMM yyyy")</div>
                            </div>
                        </div>
                        <div class="col-md-6" >
                            <div class="info-tile" style="font-size:medium">
                                <div class="text fw-bold">End Date</div>
                                <div class="text-muted">@Model.Batch.EndDate.ToString("dd MMM yyyy")</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-tile" style="font-size:medium">
                                <div class="text fw-bold">Trainer</div>
                                <div class="text-muted">@Model.Batch.HandledBy</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-tile" style="font-size:medium">
                                <div class="text fw-bold">Timings</div>
                                <div class="text-muted">@Model.Batch.Timings</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-tile" style="font-size:medium">
                                <div class="text fw-bold">Duration</div>
                                <div class="text-muted">@Model.Batch.Duration</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-tile" style="font-size:medium">
                                <div class="text fw-bold">Fee</div>
                                <div class="text-primary">₹@Model.Batch.Fee</div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3 d-flex gap-2 flex-wrap" >
                        <a asp-controller="Student" asp-action="MyBatches" class="btn btn-outline-secondary btn-md">
                            ← Back to My Batches
                        </a>
                        <a asp-controller="Student" asp-action="MyPayments" class="btn btn-outline-primary btn-md">
                            View My Payments
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex align-items-center justify-content-between mb-3">
        <h4 class="fw-bold mb-0" style="font-size:xx-large">Batch Contents</h4>

        @if (Model.Contents.Any())
        {
            <span class="text-muted small">
                Showing <span class="fw-semibold text-dark">@Model.Contents.Count</span> sessions
            </span>
        }
    </div>

@if (Model.Contents.Any())
{
        <div class="accordion" id="batchAccordion">
            @for (int i = 0; i < Model.Contents.Count; i++)
            {
                var content = Model.Contents[i];
                var collapseId = $"collapse{i}";

                <div class="accordion-item rounded-3 shadow-sm mb-2">
                    <h2 class="accordion-header" id="heading@i">
                        <button class="accordion-button collapsed fw-bold" type="button" style="font-size:large"
                                data-bs-toggle="collapse" data-bs-target="#@collapseId"
                                aria-expanded="false" aria-controls="@collapseId">
                            Session @(i + 1): @content.Topic
                            <span class="ms-3 text-muted small">
                                <i class="bi bi-calendar-event me-1"></i>
                                @content.OnDate.ToString("dd MMM yyyy")
                            </span>
                        </button>
                    </h2>

                    <div id="@collapseId" class="accordion-collapse collapse"
                         aria-labelledby="heading@i" data-bs-parent="#batchAccordion">
                        <div class="accordion-body">

                            <!-- Notes -->
                            <div class="mb-3">
                                <div class="fw-semibold mb-2">
                                    <i class="bi bi-file-earmark-pdf text-danger me-1" style="font-size:large"></i> Notes
                                </div>
                                @if (!string.IsNullOrEmpty(content.NotesDocumentPath))
                                {
                                    <a href="@Url.Content(content.NotesDocumentPath)" target="_blank"
                                       class="btn btn-outline-secondary btn-sm" style="font-size:large">
                                        Download Notes
                                    </a>
                                }
                                else
                                {
                                    <div class="small text-muted">Notes not available for this session.</div>
                                }
                            </div>

                            <!-- Video -->
                            <div>
                                <div class="fw-semibold mb-2">
                                    <i class="bi bi-camera-video text-primary me-1" style="font-size:large"></i> Video
                                </div>
                                @if (!string.IsNullOrEmpty(content.VideoFilePath))
                                {
                                    <a href="@Url.Content(content.VideoFilePath)" target="_blank"
                                       class="btn btn-outline-primary btn-sm" style="font-size:large">
                                        Watch Video
                                    </a>
                                }
                                else
                                {
                                    <div class="small text-muted">Video not available for this session.</div>
                                }
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
}
else
{
        <div class="alert alert-warning rounded-4 shadow-sm">
            <div class="fw-bold mb-1">No content available yet</div>
            <div class="small">Your trainer/admin will upload notes and videos soon.</div>
        </div>
}


<!-- ✅ Page-specific styling -->
<style>
    .info-tile {
        background: #f8fafc;
        border: 1px solid rgba(0,0,0,.06);
        border-radius: 14px;
        padding: 12px 14px;
    }

    .content-card {
        transition: all .2s ease-in-out;
    }

        .content-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 28px rgba(0,0,0,.12);
        }
</style>
@model List<Video>
@{
    ViewData["Title"] = "Course Videos";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
}

<div class="container py-4">

    <!-- ✅ Page Header -->
    <div class="mb-4  justify-content-between align-items-center">
        <!-- Right side: Back button -->
        <div class="ms-auto">
            <a asp-controller="Student"
               asp-action="SelectCourseStudent"
               class="btn btn-secondary">
                Back to Select
            </a>
        </div>
        <!-- Left side: Title -->
        <div class="text-center w-100">
            <h2 class="fw-bold mb-1">Sample Videos On</h2>
            <h3 class="text">@ViewBag.NameOfTheCourse (@Model.Count)</h3>
        </div>



    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning text-center">
            No videos available for this course yet.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var v in Model)
            {
                <div class="col-xl-4 col-lg-4 col-md-6">
                    <div class="card h-100 video-card shadow-sm border-0">

                        <!-- ✅ Video -->
                        <div class="ratio ratio-16x9 rounded-top overflow-hidden">
                            @Html.Raw(v.VideoLink)
                        </div>

                        <!-- ✅ Details -->
                        <div class="card-body d-flex flex-column">

                            <h6 class="fw-bold mb-1">
                                @v.VideoTitle
                            </h6>

                            <p class="text-muted small mb-3">
                                @{
                                    var desc = v.VideoDescription ?? "";
                                }
                                @(desc.Length > 120 ? desc.Substring(0, 120) + "..." : desc)
                            </p>

                            <div class="mt-auto text-end">
                                <!-- Optional placeholder for future actions -->
                                <span class="badge bg-light text-dark border">
                                    Video
                                </span>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- ✅ Page-specific styling -->
<style>
    .video-card {
        transition: all 0.2s ease-in-out;
        border-radius: 14px;
    }

        .video-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 32px rgba(0,0,0,0.15);
        }

        .video-card iframe {
            width: 100%;
            height: 100%;
            border: 0;
        }
</style>
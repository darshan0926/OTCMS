@model OTCMS.Components.ViewModels.EditProfileViewModel

@{
    ViewData["Title"] = "EditProfile";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
}



<div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center">
    <div class="profile-wrapper">
        <div class="card shadow-lg border-0">
            <div class="card-body p-4 p-md-5">

                <!-- Header -->
                <div class="text-center mb-3">
                    <h3 class="mb-0">Edit Profile</h3>
                    <p class="text-muted mb-0">Update your personal details</p>
                </div>

                <!-- Error Alert -->
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <hr class="mb-4" />

                <!-- Form (UNCHANGED functionality) -->
                <form asp-action="EditProfile" asp-controller="Student" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Preserve identity -->
                    <input type="hidden" asp-for="UserId" />

                    <div class="form-group mb-3">
                        <label asp-for="FirstName" class="form-label"></label>
                        <input asp-for="FirstName" class="form-control form-control-lg" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="LastName" class="form-label"></label>
                        <input asp-for="LastName" class="form-control form-control-lg" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Mobile" class="form-label"></label>
                        <input asp-for="Mobile" class="form-control form-control-lg" />
                        <div class="form-text">Enter a 10‑digit mobile number.</div>
                        <span asp-validation-for="Mobile" class="text-danger"></span>
                    </div>

                    <!-- Actions -->
                    <div class="d-flex gap-2">
                        <a asp-controller="Student" asp-action="Profile" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            Save Changes
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    /* Same background as Register */
    body {
        background: linear-gradient(135deg, #f5f7fb 0%, #e9effd 100%);
        min-height: 100vh;
    }

    /* Same wrapper sizing */
    .profile-wrapper {
        width: 100%;
        max-width: 560px;
        padding: 16px;
    }

    /* Same card polish */
    .card {
        border-radius: 16px;
    }

    .card-body {
        border-radius: 16px;
    }

    hr {
        opacity: .15;
    }
</style>
@model List<OTCMS.Components.ViewModels.MyPaymentItemViewModel>

@{
    ViewData["Title"] = "My Payments";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
    var currentSearch = ViewData["CurrentSearch"] as string;
    var currentStatus = ViewData["CurrentStatus"] as string;
}

<div class="container py-4">

    <!-- ✅ Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">My Payments</h2>
        <span class="text-muted small">
            Total Payments: @(Model?.Count ?? 0)
        </span>
    </div>

    <!-- ✅ Filters -->
    <form method="get" asp-action="MyPayments" class="card shadow-sm border-0 p-3 mb-4">
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label small text-muted">Search</label>
                <input type="text"
                       name="search"
                       value="@currentSearch"
                       class="form-control"
                       placeholder="Course, batch or payment id" />
            </div>

            <div class="col-md-3">
                <label class="form-label small text-muted">Status</label>
                <select name="status" class="form-select">
                    <option value="">All</option>
                    <option value="Inactive" selected="@(currentStatus == "Inactive")">Inactive</option>
                    <option value="Active" selected="@(currentStatus == "Active")">Active</option>
                    <option value="Approved" selected="@(currentStatus == "Approved")">Approved</option>
                    <option value="Rejected" selected="@(currentStatus == "Rejected")">Rejected</option>
                </select>
            </div>

            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    Filter
                </button>
            </div>

            <div class="col-md-2">
                <a asp-action="MyPayments" class="btn btn-outline-secondary w-100">
                    Reset
                </a>
            </div>
        </div>
    </form>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center">
            No payment records found.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle border shadow-sm">
                <thead class="table-light">
                    <tr>
                        <th>Payment Type</th>
                        <th>Course</th>
                        <th>Batch</th>
                        <th>Amount</th>
                        <th>Paid On</th>
                        <th>Status</th>
                        <th>Card</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td>
                                @* <strong>#@p.PaymentId</strong> *@
                                <div class="text-muted">
                                    @p.PaymentTypeName
                                </div>
                            </td>

                            <td>@p.CourseName</td>
                            <td>@p.BatchName</td>

                            <td class="fw-semibold">
                                ₹@p.PaymentAmount
                            </td>

                            <td>
                                @p.PaymentOn.ToLocalTime().ToString("dd MMM yyyy")
                                <div class="small text-muted">
                                    @p.PaymentOn.ToLocalTime().ToString("hh:mm tt")
                                </div>
                            </td>

                            <td>
                                <span class="badge
                                        @(p.PaymentStatus.ToString() == "Approved" ? "bg-success" :
                                                                        p.PaymentStatus.ToString() == "Active" ? "bg-primary" :
                                                                        p.PaymentStatus.ToString() == "Rejected" ? "bg-danger" :
                                                                        "bg-secondary")">
                                    @p.PaymentStatus
                                </span>
                            </td>

                            <td>
                                @if (!string.IsNullOrWhiteSpace(p.MaskedCardNumber))
                                {
                                    <div>@p.MaskedCardNumber</div>
                                    <div class="small text-muted">@p.CardHolderName</div>
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </td>

                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="PaymentSuccess"
                                       asp-route-id="@p.PaymentId"
                                       class="btn btn-outline-info">
                                        Receipt
                                    </a>

                                    @if (p.PaymentStatus.ToString() == "Approved")
                                    {
                                        <a asp-action="BatchDetails"
                                           asp-route-id="@p.BatchId"
                                           class="btn btn-outline-success">
                                            Batch
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
<style>
    /* Default card look (blue gradient) */
    .credit-card {
        background: linear-gradient(135deg, #1e3c72, #2a5298); /* deep blue gradient */
        color: #fff;
        border-radius: 15px;
        padding: 25px;
        margin-top: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
        font-family: 'Segoe UI', sans-serif;
    }

      

    .card-input {
        width: 100%;
        padding: 10px;
        border: none;
        border-radius: 8px;
        background: rgba(255,255,255,0.2);
        color: #fff;
        font-size: 1.1rem;
        letter-spacing: 2px;
    }

        .card-input::placeholder {
            color: gray;
        }

  

    .card-footer {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 15px;
    }

    .holder {
        flex: 2;
    }

    .expiry, .ccv {
        flex: 1;
    }

</style>
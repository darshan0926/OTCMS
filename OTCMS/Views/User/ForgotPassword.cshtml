@model OTCMS.Components.User

@{

    ViewData["Title"] = "ForgotPassword";

    Layout = "~/Views/Shared/_Layout.cshtml";

}
<br />
<br />
<div class="container-fluid d-flex align-items-center justify-content-center">
    <div class="forgot-wrapper">
        <form asp-action="VerifyEmail" method="post">
            <div class="card shadow-lg border-0">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-3">
                        <!-- Optional Logo Circle (replace with your image if needed) -->
                        @* Example:
<div class="rounded-circle overflow-hidden d-inline-flex align-items-center justify-content-center mb-2" 

                         style="width:60px;height:60px;">
<img src="~/images/logo.png" class="w-100 h-100" style="object-fit:cover;" />
</div>

                    *@
                        <h3 class="mb-0">Forgot Password</h3>
                        <p class="text-muted">Verify your email to reset your password</p>
                    </div>

                    <!-- Your original code starts (unchanged fields) -->
                    <h2 class="visually-hidden">Forgot Password</h2>
                    <hr class="mb-4" />

                    <div class="row">
                        <div class="col-12">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                            <div class="form-group mb-3">
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" class="form-control form-control-lg" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <input type="submit" value="Verify Email" class="btn btn-success btn-lg w-100" />

                            <div class="text-center mt-3">
                                <a asp-controller="User" asp-action="Login" class="text-decoration-none">← Back to Login</a>
                            </div>
        </form>
    </div>
</div>
<!-- End of your original code -->
</div>
</div>
</div>
</div>

@section Scripts {

    @{

        await Html.RenderPartialAsync("_ValidationScriptsPartial");

    }

}

<style>

    body {
        /* background-image: url('@Url.Content("~/images/new_background.jpg") '); */ background: linear-gradient(135deg, #f5f7fb 0%, #e9effd 100%);
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
    }

    .forgot-wrapper {
        width: 100%;
        max-width: 480px;
        padding: 16px;
    }

    .card {
        border-radius: 16px;
    }

    .card-body {
        border-radius: 16px;
    }

    hr {
        opacity: .15;
    }

    }
</style>

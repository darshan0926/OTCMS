@model OTCMS.Components.UserLogin

@{

    ViewData["Title"] = "Login";

    Layout = "_Layout";

}

<div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center">
    <div class="login-wrapper">
        <div class="card shadow-lg border-0">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-4">
                    <div class="rounded-circle overflow-hidden d-inline-flex align-items-center justify-content-center mb-2"
                         style="width:60px; height:60px;">
                        <img src="~/images/karyanova logo4.png"
                             alt="KaryaNova Logo"
                             style="width:80%; height:80%; object-fit:contain;" />
                    </div>
                    <h3 class="mb-0">Welcome Back</h3>
                    <p class="text-muted mb-0">Sign in to continue</p>
                </div>

                <hr class="mb-4" />

                <div class="row">
                    <div class="col-12">
                        <form asp-action="ValidateUser">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                            <div class="form-group mb-3">
                                <label asp-for="UserId" class="control-label"></label>
                                <input asp-for="UserId" class="form-control form-control-lg" />
                                <span asp-validation-for="UserId" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Password" class="control-label"></label>
                                <input type="password" asp-for="Password" class="form-control form-control-lg" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>

                            <div class="d-flex align-items-center justify-content-between mt-3">
                                <input type="submit" value="Login" class="btn btn-primary btn-lg px-4" />

                                <a asp-action="ForgotPassword" class="text-decoration-none fw-semibold">

                                    Forgot Password?
                                </a>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <a asp-action="Register" class="link-register">New user? <span class="fw-semibold">Create an account</span></a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {

    @{

        await Html.RenderPartialAsync("_ValidationScriptsPartial");

    }

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>

        $(document).ready(function () {

            // Check for the success message from the ResetPassword action

            var successMsg = '@TempData["SuccessMessage"]';

            if (successMsg && successMsg.length > 0) {

                // Compact Toast configuration centered

                const Toast = Swal.mixin({

                    toast: true,

                    position: 'top', // Aligns to the top-center of the page

                    showConfirmButton: false,

                    timer: 3000, // 3 seconds

                    timerProgressBar: true,

                    didOpen: (toast) => {

                        toast.addEventListener('mouseenter', Swal.stopTimer)

                        toast.addEventListener('mouseleave', Swal.resumeTimer)

                    }

                });

                Toast.fire({

                    icon: 'success',

                    title: successMsg,

                    width: '350px' // Keeps the size small even in the center

                });

            }

        });
    </script>

}

<style>

    /* Wrapper to control max width responsively */

    .login-wrapper {

        width: 100%;

        max-width: 480px;

        padding: 16px;

    }

    /* Card polish */

    .card, .card-body {

        border-radius: 16px;

    }

    /* Register/link styles */

    .link-register {

        color: #0d6efd;

        text-decoration: none;

    }

        .link-register:hover {

            text-decoration: underline;

        }

    hr {

        opacity: .15;

    }

    /* Custom Toast Styling to match your blue theme */

    .swal2-popup.swal2-toast {

        background: #ffffff;

        box-shadow: 0 5px 15px rgba(0,0,0,0.1);

        border-left: 5px solid #0d6efd;

    }
</style>

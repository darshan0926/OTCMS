@model OTCMS.Components.User

@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center">
    <div class="register-wrapper">
        <div class="card shadow-lg border-0">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-3">
                    <p class="mb-2">
                        Already registered?
                        <a asp-controller="User" asp-action="Login" class="fw-semibold text-decoration-none">
                            Login to your account
                        </a>
                    </p>

                    <h3 class="mb-0">Create your account</h3>
                    <p class="text-muted mb-0">Fill the details below to register</p>
                </div>
                

                <!-- Your original markup begins (fields unchanged) -->
                <h1 class="visually-hidden">Register</h1>

                <h4 class="visually-hidden">User</h4>
                <hr class="mb-4" />

                <div class="row">
                    <div class="col-12">
                        <form asp-action="RegisterUser">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                            <div class="form-group mb-3">
                                <label asp-for="FirstName" class="control-label"></label>
                                <input asp-for="FirstName" class="form-control form-control-lg" />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="LastName" class="control-label"></label>
                                <input asp-for="LastName" class="form-control form-control-lg" />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Email" class="control-label"></label>
                                <input asp-for="Email" class="form-control form-control-lg" id="Email" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Mobile" class="control-label"></label>
                                <input asp-for="Mobile" class="form-control form-control-lg" />
                                <span asp-validation-for="Mobile" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Password" class="control-label"></label>
                                <input asp-for="Password" class="form-control form-control-lg" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="ConfirmPassword" class="control-label"></label>
                                <input asp-for="ConfirmPassword" type="password" class="form-control form-control-lg" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>

                            @* Keep these commented blocks as-is (unchanged)
                            <div class="form-group">
                                <label asp-for="UserId" class="control-label"></label>
                                <input asp-for="UserId" class="form-control" />
                                <span asp-validation-for="UserId" class="text-danger"></span>
                            </div>
                            <input asp-for="UserId" type="hidden" id="UserId" />
                            *@


                            @* Keep these commented blocks as-is (unchanged)
                            <div class="form-group">
                                <label asp-for="RoleId" class="control-label"></label>
                                <select asp-for="RoleId" class="form-control" asp-items="ViewBag.RoleId"></select>
                            </div>
                            <input type="hidden" asp-for="RoleId" />
                            *@

                            <div class="form-group mb-3">
                                <label>Role</label>
                                <input type="hidden" asp-for="RoleId" />
                                <input type="text" class="form-control form-control-lg" value="@ViewBag.DefaultRoleName" readonly />
                            </div>

                            <div class="form-group mt-4">
                                <input type="submit" value="Register" class="btn btn-primary btn-lg w-100" />
                            </div>
                        </form>
                    </div>
                </div>
                <!-- Your original markup ends -->

                <div class="text-center mt-3">
                    <a asp-controller="Home" asp-action="Index" class="link-secondary text-decoration-none">
                        ← Back to Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    /* Page background (same style as login for consistency) */
    body {
        /* background-image: url('@Url.Content("~/images/new_background.jpg") '); */ background: linear-gradient(135deg, #f5f7fb 0%, #e9effd 100%);
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
    }

    /* Wrapper for nice max width */
    .register-wrapper {
        width: 100%;
        max-width: 560px; /* slightly wider than login for more fields */
        padding: 16px;
    }

    /* Card polish */
    .card {
        border-radius: 16px;
    }

    .card-body {
        border-radius: 16px;
    }

    /* Softer hr */
    hr {
        opacity: .15;
    }

    }
</style>
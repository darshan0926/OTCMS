@{

    ViewData["Title"] = "ResetPassword";

    Layout = "~/Views/Shared/_Layout.cshtml";

}

<div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center">
    <div class="reset-wrapper">
        <form asp-action="ResetPasswordUser" method="post">
            <div class="card shadow-lg border-0">
                <div class="card-body p-4 p-md-5">

                    <div class="text-center mb-3">
                        <h3 class="mb-0">Reset Password</h3>
                        <p class="text-muted mb-0">Create a strong new password</p>
                    </div>

                    <h2 class="visually-hidden">Reset Password</h2>
                    <hr class="mb-4" />

                    <div class="row">
                        <div class="col-12">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            <input type="hidden" name="email" value="@ViewBag.Email" />

                            <div class="form-group mb-3">
                                <label for="newPassword">New Password</label>
                                <input type="password" name="newPassword" class="form-control form-control-lg" minlength="6" maxlength="15" required />
                            </div>

                            <div class="form-group mb-3">
                                <label for="confirmPassword">Confirm Password</label>
                                <input type="password" name="confirmPassword" class="form-control form-control-lg" minlength="6" maxlength="15" required />
                            </div>

                            <input type="submit" value="Reset Password" class="btn btn-success btn-lg w-100" />

                            <div class="text-center mt-3">
                                <a asp-controller="User" asp-action="ForgotPassword" class="text-decoration-none text-muted small">Cancel and go back</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {

    @{

        await Html.RenderPartialAsync("_ValidationScriptsPartial");

    }

}

<style>

    body {
        background: linear-gradient(135deg, #f5f7fb 0%, #e9effd 100%);
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
    }

    .reset-wrapper {
        width: 100%;
        max-width: 480px;
        padding: 16px;
    }

    .card {
        border-radius: 16px;
    }

    .card-body {
        border-radius: 16px;
    }

    hr {
        opacity: .15;
    }

    /* 2. REMOVED THE EXTRA BRACE THAT WAS HERE */
</style>


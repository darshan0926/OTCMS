
@model OTCMS.Components.Video

@{
    ViewData["Title"] = "Create Video";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mb-4 text-primary">Create Video</h1>

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">Video Information</h4>
    </div>

    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="CourseId" class="form-label">Select Course</label>
                <select asp-for="CourseId" class="form-control" asp-items="ViewBag.CourseId"></select>
            </div>
            <div class="form-group mb-3">
                <label asp-for="VideoTitle" class="form-label">Video Title</label>
                <input asp-for="VideoTitle" class="form-control" placeholder="Enter Video Title" />
                <span asp-validation-for="VideoTitle" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="VideoDescription" class="form-label">Video Description</label>
                <textarea asp-for="VideoDescription" class="form-control" rows="4" placeholder="Enter Video Description"></textarea>
                <span asp-validation-for="VideoDescription" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="VideoLink" class="form-label">Video Link</label>
                <input asp-for="VideoLink" class="form-control" placeholder="Enter YouTube / Vimeo Link" />
                <span asp-validation-for="VideoLink" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="Status" />
                <label class="form-check-label" asp-for="Status">Active Status</label>
            </div>

            @* <div class="form-group mb-3">
                <label asp-for="CreatedOn" class="form-label">Created On</label>
                <input asp-for="CreatedOn" class="form-control" />
                <span asp-validation-for="CreatedOn" class="text-danger"></span>
            </div> *@

            

            <div class="form-group mt-4">
                <input type="submit" value="Create" class="btn btn-success" />
                <a asp-action="Index" class="btn btn-secondary ms-2">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>

        </form>
    </div>
</div>

<style>
    body {
        /* background-image: url('@Url.Content("~/images/new_background.jpg")'); */
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

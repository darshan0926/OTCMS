
@model OTCMS.Components.Video

@{
    ViewData["Title"] = "Delete Video";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="text-danger mb-4">Delete Video</h1>
<form asp-action="delete">
<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4 class="mb-0">Are you sure you want to delete this video?</h4>
    </div>

    <div class="card-body">
        <dl class="row">

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.VideoTitle)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.VideoTitle)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.VideoDescription)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.VideoDescription)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.VideoLink)</dt>
            <dd class="col-sm-9">
                @Html.Raw(Model.VideoLink)
            </dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.Status)</dt>
            <dd class="col-sm-9">
                @(Model.Status ? "Active" : "Inactive")
            </dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.CreatedOn)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.CreatedOn)</dd>

            <dt class="col-sm-3 fw-bold">Course Name</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.course.NameOfTheCourse)</dd>

        </dl>

    
            <input type="hidden" asp-for="CourseVideoId" />

            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash"></i> Confirm Delete
            </button>

            <a asp-action="Index" class="btn btn-secondary ms-2">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </form>
    </div>
</div>

<style>
    body {
        /* background-image: url('@Url.Content("~/images/new_background.jpg")'); */
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
    }
</style>

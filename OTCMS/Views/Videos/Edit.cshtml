
@model OTCMS.Components.Video

@{
    ViewData["Title"] = "Edit Video";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mb-4 text-primary">Edit Video</h1>

<div class="card shadow-sm">
    <div class="card-header bg-warning text-dark">
        <h4 class="mb-0">Update Video Information</h4>
    </div>

    <div class="card-body">
        <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <input type="hidden" asp-for="CourseVideoId" />

            <div class="form-group mb-3">
                <label asp-for="VideoTitle" class="form-label"></label>
                <input asp-for="VideoTitle" class="form-control" placeholder="Enter video title" />
                <span asp-validation-for="VideoTitle" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="VideoDescription" class="form-label"></label>
                <!-- Keeping your same binding; changed only UI and spacing -->
                <input asp-for="VideoDescription" class="form-control" placeholder="Enter video description" />
                <span asp-validation-for="VideoDescription" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="VideoLink" class="form-label"></label>
                <input asp-for="VideoLink" class="form-control" placeholder="Enter video link" />
                <span asp-validation-for="VideoLink" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="Status" />
                <label class="form-check-label" asp-for="Status">
                    @Html.DisplayNameFor(model => model.Status)
                </label>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CreatedOn" class="form-label"></label>
                <input asp-for="CreatedOn" class="form-control" />
                <span asp-validation-for="CreatedOn" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CourseId" class="form-label"></label>
                <select asp-for="CourseId" class="form-control" asp-items="ViewBag.CourseId"></select>
                <span asp-validation-for="CourseId" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Save Changes
                </button>

                <a asp-action="Index" class="btn btn-secondary ms-2">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </form>
    </div>
</div>

<style>
    body {
        /* background-image: url('@Url.Content("~/images/new_background.jpg")'); */
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
